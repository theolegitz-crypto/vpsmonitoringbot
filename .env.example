APP_NAME=SwagMonitor
API_PREFIX=/api
DEBUG=false

POSTGRES_DB=monitoringswagbot
POSTGRES_USER=monitor
POSTGRES_PASSWORD=monitor

DATABASE_URL=postgresql+asyncpg://monitor:monitor@db:5432/monitoringswagbot
ALEMBIC_DATABASE_URL=postgresql+psycopg://monitor:monitor@db:5432/monitoringswagbot

ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost"]

SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=30
RUN_INITIAL_CHECKS=true

PING_ATTEMPTS=4
PING_TIMEOUT_SECONDS=1
DEFAULT_CHECK_INTERVAL_SECONDS=60
DEFAULT_CONSECUTIVE_ALERT_THRESHOLD=3
HTTP_TIMEOUT_SECONDS=5
SSL_WARNING_DAYS=21

TELEGRAM_BOT_TOKEN=replace_me
# Examples: 123456789 or -1001234567890:42
TELEGRAM_ADMIN_CHAT_IDS=123456789
# Restrict bot commands to specific group/topic targets. Leave empty to allow all chats.
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOW_PRIVATE_CHATS=true

AUTH_ENABLED=true
AUTH_COOKIE_NAME=swagmonitor_session
AUTH_SESSION_TTL_HOURS=72
AUTH_COOKIE_SECURE=false
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=change_me_now

PANEL_BASIC_AUTH_ENABLED=false
PANEL_AUTH_USER=admin
PANEL_AUTH_PASSWORD=change_me_now
