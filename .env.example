APP_NAME=SwagMonitor
API_PREFIX=/api
DEBUG=false

POSTGRES_DB=monitoringswagbot
POSTGRES_USER=monitor
POSTGRES_PASSWORD=monitor

DATABASE_URL=postgresql+asyncpg://monitor:monitor@db:5432/monitoringswagbot
ALEMBIC_DATABASE_URL=postgresql+psycopg://monitor:monitor@db:5432/monitoringswagbot

ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost"]

SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=30
RUN_INITIAL_CHECKS=true
CLEANUP_INTERVAL_HOURS=6

PING_ATTEMPTS=4
PING_TIMEOUT_SECONDS=1
DEFAULT_CHECK_INTERVAL_SECONDS=60
DEFAULT_CONSECUTIVE_ALERT_THRESHOLD=3
HTTP_TIMEOUT_SECONDS=5
SSL_WARNING_DAYS=21
FAILURE_RETRY_ENABLED=true
FAILURE_RETRY_ATTEMPTS=1
FAILURE_RETRY_DELAY_SECONDS=3
DIAGNOSTICS_ENABLED=true
TRACEROUTE_ENABLED=true
TRACEROUTE_MAX_HOPS=12
TRACEROUTE_TIMEOUT_SECONDS=2
CHECK_RESULTS_RETENTION_DAYS=30
CHECK_RESULT_ROLLUP_RETENTION_DAYS=365
AGENT_METRICS_RETENTION_DAYS=14
CONTAINER_METRICS_RETENTION_DAYS=14
DIAGNOSTIC_RETENTION_DAYS=14
SPEED_TEST_RETENTION_DAYS=30
SPEED_TEST_DEGRADATION_ALERT_ENABLED=true
SPEED_TEST_BASELINE_SAMPLES=5
SPEED_TEST_BASELINE_MIN_SAMPLES=3
SPEED_TEST_BASELINE_WINDOW_HOURS=168
SPEED_TEST_WARNING_RATIO=0.7
SPEED_TEST_CRITICAL_RATIO=0.5
SPEED_TEST_PING_WARNING_MULTIPLIER=1.5
SPEED_TEST_PING_CRITICAL_MULTIPLIER=2.0
SPEED_TEST_ALERT_COOLDOWN_MINUTES=180
SPEED_TEST_RECOVERY_WINDOW_HOURS=24
ALERT_EVENTS_RETENTION_DAYS=90
RESOLVED_INCIDENT_RETENTION_DAYS=90
AGENT_INGEST_ENABLED=true
AGENT_SHARED_TOKEN=replace_with_long_random_token

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_ADMIN_CHAT_IDS=123456789
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOW_PRIVATE_CHATS=true

AUTH_ENABLED=true
AUTH_COOKIE_NAME=swagmonitor_session
AUTH_SESSION_TTL_HOURS=72
AUTH_COOKIE_SECURE=false
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=change_me_now

PANEL_BASIC_AUTH_ENABLED=false
PANEL_AUTH_USER=admin
PANEL_AUTH_PASSWORD=change_me_now

# Agent example
# AGENT_BACKEND_URL=http://127.0.0.1:8000
# AGENT_SERVER_NAME=vps1
# AGENT_SHARED_TOKEN=replace_with_long_random_token
# AGENT_INTERVAL_SECONDS=30
# AGENT_ENABLE_DOCKER=true
# AGENT_SPEEDTEST_ENABLED=true
